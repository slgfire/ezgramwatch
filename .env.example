# ============================================================
# ezgramwatch — environment configuration
# Copy this file to .env and fill in your values.
# ============================================================

# Required ─────────────────────────────────────────────────

# Discord Webhook URL
# Create under: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/<channel_id>/<token>

# Instagram Graph API long-lived User Access Token
# Obtain from your Meta for Developers app dashboard.
# The token must have instagram_basic + pages_read_engagement permissions.
INSTAGRAM_ACCESS_TOKEN=<your_long_lived_access_token>

# One or more Instagram Business/Creator account IDs, comma-separated.
# Format: <ig_user_id>[:display_name]
# The IG user ID is the numeric ID of the Business/Creator account (not the username).
# Example: 17841400000000001:brand1,17841400000000002:brand2
INSTAGRAM_ACCOUNTS=<ig_user_id>:<display_name>

# Optional: Token auto-refresh ────────────────────────────
# Provide these to enable automatic token refresh before expiry (< 7 days left).
# Without them the bot logs a warning but continues with the existing token.
# Find both in Meta for Developers → Your App → App Settings → Basic.
#META_APP_ID=<your_meta_app_id>
#META_APP_SECRET=<your_meta_app_secret>

# Optional: Polling ────────────────────────────────────────
#POLL_INTERVAL_SECONDS=300       # How often to check for new posts (default: 300 s)
#MEDIA_FETCH_LIMIT=25            # Max items fetched per poll, 1–100 (default: 25)

# Optional: First-run behaviour ────────────────────────────
#POST_EXISTING_ON_FIRST_RUN=false  # Post existing posts on first start? (default: false)
#FIRST_RUN_POST_LIMIT=10           # Max posts to send on first run if above is true (default: 10)

# Optional: Formatting ─────────────────────────────────────
#CAPTION_PREVIEW_CHARS=300       # How many caption characters to show in embeds (default: 300)

# Optional: Infrastructure ─────────────────────────────────
#LOG_LEVEL=info                  # trace | debug | info | warn | error | fatal (default: info)
#DATABASE_PATH=/data/bot.sqlite  # SQLite file path inside the container (default: /data/bot.sqlite)
#GRAPH_API_VERSION=v21.0         # Meta Graph API version pin (default: v21.0)
